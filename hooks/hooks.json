{
  "description": "Blueprint 로컬 에이전트 세션 등록·해제 (EDIT_REQUEST 기능용)",
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|resume|clear",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/register-session.sh",
            "timeout": 3
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/unregister-session.sh",
            "timeout": 3
          }
        ]
      }
    ]
  }
}
